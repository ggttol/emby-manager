{
  "name": "emby-manager-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5178",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "openapi:json": "cargo run --quiet --manifest-path ../Cargo.toml -- openapi",
    "openapi:types": "tmp=$(mktemp) && npm run openapi:json --silent > \"$tmp\" && openapi-typescript \"$tmp\" -o src/api/openapi.d.ts && rm -f \"$tmp\""
  },
  "dependencies": {
    "lucide-react": "^0.555.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "jsdom": "^27.2.0",
    "openapi-typescript": "^7.10.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.14"
  }
}
