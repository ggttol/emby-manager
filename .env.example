EMBY_MANAGER_BIND_IP=127.0.0.1
EMBY_MANAGER_HTTP_PORT=8098
# Required: fill these before running docker compose. Empty values make
# compose fail fast instead of starting with a sample password.
EMBY_MANAGER_BOOTSTRAP_PASSWORD=
POSTGRES_PASSWORD=

# Optional: set these to the NAS uid/gid that can read STRM/CloudDrive bind mounts.
EMBY_MANAGER_UID=10001
EMBY_MANAGER_GID=10001

# Optional overrides for NAS paths.
EMBY_MANAGER_LEGACY_DIR=./legacy
EMBY_MANAGER_DATA_DIR=./data
EMBY_MANAGER_STRM_ROOT=/volume1/strm
# Conservative gray release default: read-only. Set rw only when Rust should
# write STRM files or perform STRM cleanup/delete/move operations.
EMBY_MANAGER_STRM_MODE=ro
EMBY_MANAGER_MEDIA_ROOT=/volume1/docker/clouddrive2/CloudNAS/CloudDrive
# Keep CloudDrive/media read-only unless you explicitly enable real delete/move
# operations under the media root.
EMBY_MANAGER_MEDIA_MODE=ro
